# .env.example
# Copiar como .env.local para desarrollo local.
# En Vercel: Settings → Environment Variables

# ── Google Sheets ──────────────────────────────────────────────────────────────
# JSON completo de la Service Account key (una sola línea)
# Pasos: Google Cloud Console → IAM → Service Accounts → Crear clave JSON
# Compartir cada hoja con el email de la SA (Lectura).
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"tu-sa@tu-proyecto.iam.gserviceaccount.com"}

# ID del Google Spreadsheet (el string largo entre /d/ y /edit en la URL)
SPREADSHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# ── Email (nodemailer via Gmail SMTP) ─────────────────────────────────────────
# Crear un App Password en: Google Account → Seguridad → Contraseñas de aplicaciones
# (requiere tener verificación en 2 pasos activada)
SMTP_USER=reportes@tuempresa.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── Warm-up cron (cada 1 hora) ────────────────────────────────────────────────
# Vercel setea CRON_SECRET automáticamente en producción.
# Para disparar manualmente: GET /api/warmUp?secret=TU_WARM_UP_SECRET
WARM_UP_SECRET=un-secreto-largo-para-llamadas-manuales
